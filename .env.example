# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Environment: "development" or "production"
ENVIRONMENT=development

# Security - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# Development (SQLite - auto-created, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./f1_analytics.db

# Production (MySQL on PythonAnywhere) - uncomment when deploying
# DATABASE_URL=mysql+pymysql://username:password@username.mysql.pythonanywhere-services.com/username$f1_analytics

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=F1 Analytics API
PROJECT_VERSION=1.0.0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_STATIC_ROOT=./staticfiles

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS - comma-separated list of allowed origins
# Development: allow localhost
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
